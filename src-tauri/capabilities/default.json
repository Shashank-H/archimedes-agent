{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Default app capability",
  "windows": ["main"],
  "permissions": [
    "opener:default",
    {
      "identifier": "http:default",
      "allow": [
        { "url": "https://auth.openai.com/**" },
        { "url": "https://chatgpt.com/**" }
      ]
    }
  ]
}
